generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  createdAt    DateTime @default(now())

  submissions  Submission[]
  classrooms   ClassroomMember[]
  leaderboard  Leaderboard?
  badges             Badge[]
  challenges         Challenge[]
  teacherClassrooms  Classroom[]       @relation("TeacherClassrooms")
}

model Submission {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  challengeId String
  code      String           @db.Text
  language  String
  status    SubmissionStatus @default(PENDING)
  verdict   String
  runtime   Float?
  memory    Int?
  output    String?          @db.Text
  error     String?          @db.Text
  score     Int              @default(0)
  createdAt DateTime         @default(now())

  @@index([userId, challengeId])
}

model Leaderboard {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  totalScore     Int      @default(0)
  problemsSolved Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Badge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  icon      String
  awardedAt DateTime @default(now())

  @@unique([userId, name])
}

model Classroom {
  id           String            @id @default(uuid())
  name         String
  joinCode     String            @unique
  teacherId    String
  teacher      User              @relation("TeacherClassrooms", fields: [teacherId], references: [id])
  meetLink     String?
  scheduleDays String?
  scheduleTime String?
  createdAt    DateTime          @default(now())
  members      ClassroomMember[]
}

model ClassroomMember {
  id          String    @id @default(uuid())
  userId      String
  classroomId String
  user        User      @relation(fields: [userId], references: [id])
  classroom   Classroom @relation(fields: [classroomId], references: [id])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
}

model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  difficulty  String   @default("MEDIUM")
  rating      Int?
  tags        String[]
  sampleInput String   @db.Text
  sampleOutput String  @db.Text
  testCases   Json?
  createdAt   DateTime @default(now())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
}
